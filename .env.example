# Fábrica de Sistemas - configuração base portável
# Copie para .env.local ou .env.vps conforme o perfil.

FACTORY_PROFILE=LOCAL_WINDOWS
FACTORY_ENV=development
FACTORY_NAME=Fabrica de Sistemas
FACTORY_TIMEZONE=America/Sao_Paulo

# Portas
FACTORY_API_HOST_PORT=8000
FORJA_OS_HOST_PORT=8080

# Diretórios portáveis.
# Use caminhos relativos para LOCAL_WINDOWS e PORTABLE_USB.
FACTORY_DATA_DIR=./data
FACTORY_LOG_DIR=./logs
FACTORY_BACKUP_DIR=./backups
FACTORY_CONFIG_DIR=./config

# Banco de dados.
# Dentro do container, o banco fica em /app/data; o host escolhe FACTORY_DATA_DIR.
DATABASE_URL=sqlite:////app/data/nexus.db
FACTORY_DATABASE_FILE=nexus.db

# Logs
LOG_LEVEL=INFO
LOG_FORMAT=json

# Segurança
# Nunca grave valores reais nos exemplos. Use .env.local, .env.vps ou cofre externo.
SECRET_KEY=CHANGE_ME_OUTSIDE_GIT
JWT_SECRET=CHANGE_ME_OUTSIDE_GIT
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# LLM / provedores
OLLAMA_BASE_URL=http://host.docker.internal:11434
LLM_PROVIDER_MODE=router
LLM_ROUTER_ENABLED=true
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-pro

# Docker
COMPOSE_PROJECT_NAME=fabrica
FACTORY_RESTART_POLICY=unless-stopped
