# Perfil LOCAL_WINDOWS
# Copie para .env.local e ajuste apenas se necessário.

FACTORY_PROFILE=LOCAL_WINDOWS
FACTORY_ENV=development
FACTORY_NAME=Fabrica de Sistemas Local
FACTORY_TIMEZONE=America/Sao_Paulo

FACTORY_API_HOST_PORT=8000
FORJA_OS_HOST_PORT=8080

FACTORY_DATA_DIR=./data
FACTORY_LOG_DIR=./logs
FACTORY_BACKUP_DIR=./backups
FACTORY_CONFIG_DIR=./config

DATABASE_URL=sqlite:////app/data/nexus.db
FACTORY_DATABASE_FILE=nexus.db

LOG_LEVEL=INFO
LOG_FORMAT=json

SECRET_KEY=CHANGE_ME_LOCAL_ONLY
JWT_SECRET=CHANGE_ME_LOCAL_ONLY
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

OLLAMA_BASE_URL=http://host.docker.internal:11434
LLM_PROVIDER_MODE=router
LLM_ROUTER_ENABLED=true

COMPOSE_PROJECT_NAME=fabrica-local
FACTORY_RESTART_POLICY=unless-stopped
