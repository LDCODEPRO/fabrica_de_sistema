# Perfil VPS_LINUX
# Copie para .env.vps no servidor e substitua os segredos fora do Git.

FACTORY_PROFILE=VPS_LINUX
FACTORY_ENV=production
FACTORY_NAME=Fabrica de Sistemas VPS
FACTORY_TIMEZONE=America/Sao_Paulo

FACTORY_API_HOST_PORT=8000
FORJA_OS_HOST_PORT=8080

# Em VPS, use diretórios persistentes do servidor.
FACTORY_DATA_DIR=./data
FACTORY_LOG_DIR=./logs
FACTORY_BACKUP_DIR=./backups
FACTORY_CONFIG_DIR=./config

DATABASE_URL=sqlite:////app/data/nexus.db
FACTORY_DATABASE_FILE=nexus.db

LOG_LEVEL=INFO
LOG_FORMAT=json

SECRET_KEY=CHANGE_ME_IN_VPS_SECRET_STORE
JWT_SECRET=CHANGE_ME_IN_VPS_SECRET_STORE
CORS_ORIGINS=https://forja.example.com

# Em Linux com Docker, host.docker.internal pode exigir host-gateway no compose.
OLLAMA_BASE_URL=http://host.docker.internal:11434
LLM_PROVIDER_MODE=router
LLM_ROUTER_ENABLED=true

COMPOSE_PROJECT_NAME=fabrica-vps
FACTORY_RESTART_POLICY=unless-stopped
